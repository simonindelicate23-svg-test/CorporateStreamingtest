# ── Core ──────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8888

# ── FTP / Media storage ───────────────────────────────────────────
FTP_HOST=
FTP_USER=
FTP_PASSWORD=
FTP_PUBLIC_BASE_URL=
FTP_BASE_PATH=uploads
FTP_SECURE=false

# ── Admin ─────────────────────────────────────────────────────────
# Generate any random secret string — this is your admin password.
ADMIN_API_TOKEN=

# ── Catalogue discovery (optional) ────────────────────────────────
# Set to true to allow your catalogue to appear in public discovery APIs.
DISCOVERY_OPT_IN=false

# ── PayPal payments (optional, for gated/paid content) ────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
