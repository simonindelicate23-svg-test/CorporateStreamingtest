# ── Core ──────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8888

# ── S3-compatible media storage (priority: S3 → FTP → local) ─────
#
# Works with any S3-compatible provider. Recommended: Backblaze B2
# (free signup, no credit card, 10 GB free storage, cheap egress).
#
# For Backblaze B2:
#   S3_ENDPOINT   = https://s3.<region>.backblazeb2.com
#                   (find your region in B2 dashboard under "Endpoint")
#   S3_REGION     = us-west-004  (or whatever region your bucket is in)
#   R2_ACCESS_KEY_ID     = your B2 applicationKeyId
#   R2_SECRET_ACCESS_KEY = your B2 applicationKey
#   R2_BUCKET_NAME       = your bucket name
#   R2_PUBLIC_BASE_URL   = https://f004.backblazeb2.com/file/<bucket-name>
#                          (replace f004 with your B2 download URL prefix)
#
# For Cloudflare R2 (requires payment card on account):
#   Leave S3_ENDPOINT blank and set R2_ACCOUNT_ID instead.
#   R2_PUBLIC_BASE_URL must be a custom domain connected to the bucket.
#
S3_ENDPOINT=
S3_REGION=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# ── FTP / Media storage (used when R2 vars are not set) ───────────
FTP_HOST=
FTP_USER=
FTP_PASSWORD=
FTP_PUBLIC_BASE_URL=
FTP_BASE_PATH=uploads
FTP_SECURE=false

# ── Admin ─────────────────────────────────────────────────────────
# Generate any random secret string — this is your admin password.
ADMIN_API_TOKEN=

# ── Catalogue discovery ───────────────────────────────────────────
# You do NOT need to set this. Discovery is controlled by the toggle in
# Admin Settings → "Expose catalogue API". This env var only sets the
# initial default before you've saved admin settings for the first time.
# DISCOVERY_OPT_IN=false

# ── PayPal payments (optional, for gated/paid content) ────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
